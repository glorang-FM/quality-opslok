# Copy to .env and fill in values

# PostgreSQL (Supabase connection string)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# JWT signing key — change this in production
JWT_SECRET=quality-opslok-secret-change-in-production

# CORS — where the React client is served from
CLIENT_URL=http://localhost:5174

# Server port (default: 3002)
PORT=3002

# Set to 'production' on Render
NODE_ENV=development

# ── Billing (dormant until set to 'true') ────────────────────────────────────
BILLING_ENFORCED=false
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Push notifications (optional) ────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_MAILTO=mailto:you@company.com

# ── Email (Resend) ────────────────────────────────────────────────────────────
# RESEND_API_KEY=re_...
# EMAIL_FROM=Quality OpsLok <noreply@quality.opslok.com>

# ── Super-admin secret (for domain restriction changes) ──────────────────────
# OWNER_SECRET=some-random-secret
